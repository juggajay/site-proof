{
  "headers": [
    {
      "source": "/((?!assets/|api/|.*\\.(?:js|css|png|jpg|jpeg|svg|ico|webp|woff2?|map|json|txt|xml)).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(sw.js|registerSW.js|manifest.webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|api/|.*\\.(?:js|css|png|jpg|jpeg|svg|ico|webp|woff2?|map|json|txt|xml)).*)",
      "destination": "/index.html"
    }
  ],
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"master\" ]; then exit 1; else exit 0; fi"
}
