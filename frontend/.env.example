# Local development backend API URL.
# Production builds must use /api or a public HTTPS origin.
VITE_API_URL=http://localhost:3001
VITE_ALLOW_MOCK_OAUTH=false

# Supabase. Leave VITE_SUPABASE_URL blank in production unless browser
# Supabase access is enabled for a real project.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
