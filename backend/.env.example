# Database - PostgreSQL connection string
# Connection pool: append ?connection_limit=10&pool_timeout=30 for production
DATABASE_URL="postgresql://user:password@localhost:5432/siteproof?schema=public"
# Disposable database used only by Prisma drift checks. Prisma may reset it.
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/siteproof_shadow?schema=public"
# Vitest refuses non-local or non-disposable DATABASE_URL values unless this is explicitly true.
ALLOW_EXTERNAL_TEST_DATABASE=false

# Supabase / file storage
# Production requires SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY unless
# ALLOW_LOCAL_FILE_STORAGE=true is explicitly set for persistent local storage.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# Optional for browser/client integrations; server uploads require the service role key in production.
SUPABASE_ANON_KEY=""
ALLOW_LOCAL_FILE_STORAGE=false

# JWT Authentication
JWT_SECRET="your-jwt-secret-min-32-chars"
# 32 random bytes encoded as 64 hex characters. Required in production for MFA/TOTP secret encryption.
ENCRYPTION_KEY="your-64-character-hex-encryption-key"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@siteproof.app"
EMAIL_ENABLED=true
# Development/test only. Production requires a valid RESEND_API_KEY and will not mock delivery.
EMAIL_PROVIDER=resend
# Scheduled reports run automatically in production unless disabled.
SCHEDULED_REPORT_WORKER_ENABLED=true
SCHEDULED_REPORT_WORKER_INTERVAL_MS=60000
# Digest notification emails run automatically in production unless disabled.
NOTIFICATION_DIGEST_WORKER_ENABLED=true
NOTIFICATION_DIGEST_WORKER_INTERVAL_MS=900000
NOTIFICATION_DIGEST_TIME_OF_DAY="17:00"
# Notification reminder, backlog, system alert, and escalation automation.
NOTIFICATION_AUTOMATION_WORKER_ENABLED=true
NOTIFICATION_AUTOMATION_WORKER_INTERVAL_MS=3600000
DIARY_REMINDER_TIME_OF_DAY="17:00"

# Support contact info
SUPPORT_EMAIL="support@siteproof.com.au"
SUPPORT_PHONE=""
SUPPORT_PHONE_LABEL=""
SUPPORT_EMERGENCY_PHONE=""
SUPPORT_ADDRESS=""
SUPPORT_HOURS="Mon-Fri, 8am-6pm AEST"
SUPPORT_RESPONSE_CRITICAL="Within 2 hours"
SUPPORT_RESPONSE_STANDARD="Within 24 hours"
SUPPORT_RESPONSE_GENERAL="Within 48 hours"

# Push notifications
# Generate persistent keys once with /api/push/generate-vapid-keys in development.
# Production will not auto-generate throwaway keys.
# If VAPID keys are configured in production, VAPID_SUBJECT is required.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@siteproof.com"

# Anthropic AI
# Certificate extraction falls back to manual review when ANTHROPIC_API_KEY is not configured.
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
ANTHROPIC_TEST_CERT_MODEL="claude-3-5-haiku-20241022"
ANTHROPIC_DOCUMENT_CLASS_MODEL="claude-3-5-haiku-20241022"

# Frontend URL (for CORS and email links)
# Production startup requires this to be a public HTTPS URL, not localhost.
FRONTEND_URL="http://localhost:5174"

# Public backend URL (for signed download links and uploaded media URLs)
# Production startup requires BACKEND_URL or API_URL to be a public HTTPS URL, not localhost.
BACKEND_URL="http://localhost:3001"
API_URL="http://localhost:3001"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Production Google OAuth redirect URI must also be public HTTPS.
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"
# Development only. Enables /api/auth/oauth/mock and missing-Google-client mock redirect.
ALLOW_MOCK_OAUTH=false

# Server
PORT=3001
NODE_ENV=development
ERROR_LOG_TO_FILE=true
ERROR_LOG_MAX_BYTES=5242880

# Rate limiting
# Production defaults to the database-backed store so limits and lockouts work across instances.
# Set RATE_LIMIT_STORE=memory only for local/dev single-process use.
RATE_LIMIT_STORE=memory
API_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=50
SUPPORT_RATE_LIMIT_MAX=10
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION_MS=900000
# Optional when JWT_SECRET is strong; if set in production, use a unique random value.
RATE_LIMIT_KEY_SALT=""

# Webhooks
WEBHOOK_DELIVERY_TIMEOUT_MS=10000

# Reverse proxy
# Set to true only when Express is behind a trusted proxy/load balancer that owns X-Forwarded-* headers.
TRUST_PROXY=false
