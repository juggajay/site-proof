{
  "name": "siteproof-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:diff": "node scripts/check-migration-drift.mjs",
    "db:studio": "prisma studio",
    "db:backup": "tsx scripts/backup.ts create",
    "db:backup:list": "tsx scripts/backup.ts list",
    "seed:itp": "node scripts/seeds/itp-templates/index.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "preflight:integrations": "tsx scripts/preflight-production-integrations.ts",
    "reports:send-due": "tsx scripts/process-scheduled-reports.ts",
    "notifications:send-digests": "tsx scripts/send-notification-digests.ts",
    "notifications:process-automation": "tsx scripts/process-notification-automation.ts",
    "migrate:status": "tsx scripts/migrate.ts status",
    "migrate:deploy": "tsx scripts/migrate.ts deploy",
    "migrate:history": "tsx scripts/migrate.ts history",
    "seed:e2e": "node scripts/seed-e2e.mjs",
    "lint": "eslint src/ scripts/migrate.ts scripts/backup.ts scripts/data-retention.ts scripts/migrate-passwords.ts scripts/preflight-production-integrations.ts scripts/process-scheduled-reports.ts scripts/send-notification-digests.ts scripts/process-notification-automation.ts scripts/check-migration-drift.mjs scripts/seed-e2e.mjs scripts/seeds/itp-templates/index.mjs scripts/smoke-production.mjs",
    "lint:fix": "eslint src/ scripts/migrate.ts scripts/backup.ts scripts/data-retention.ts scripts/migrate-passwords.ts scripts/preflight-production-integrations.ts scripts/process-scheduled-reports.ts scripts/send-notification-digests.ts scripts/process-notification-automation.ts scripts/check-migration-drift.mjs scripts/seed-e2e.mjs scripts/seeds/itp-templates/index.mjs scripts/smoke-production.mjs --fix",
    "format": "prettier --write \"src/**/*.{ts,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css,json}\"",
    "type-check": "tsc --noEmit && tsc -p tsconfig.scripts.json"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "otplib": "^13.1.1",
    "qrcode": "^1.5.4",
    "resend": "^2.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "overrides": {
    "minimatch": "^9.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.14.0",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.17"
  }
}
